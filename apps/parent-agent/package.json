  "dependencies": {
    "@autoresearch/auth": "workspace:*",
    "@autoresearch/bandit": "workspace:*",
    "@autoresearch/convex": "workspace:*",
    "@autoresearch/deliverables": "workspace:*",
    "@autoresearch/prompts": "workspace:*",
    "@autoresearch/schemas": "workspace:*",
    "@autoresearch/shared": "workspace:*",
    "@anthropic-ai/sdk": "^0.40.0",
    "@fal-ai/client": "^1.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@stripe/agent-toolkit": "^0.7.0",
    "@tensorlake/sdk": "^0.5.0",
    "convex": "^1.17.0",
    "exa-js": "^1.5.0",
    "openai": "^5.0.0",
    "resend": "^4.0.0",
    "stripe": "^18.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "tsx": "^4.19.0",
    "@types/node": "^24.0.0"
