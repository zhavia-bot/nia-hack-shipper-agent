{
  "name": "@autoresearch/parent-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/orchestrator.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/orchestrator.ts",
    "start": "node dist/orchestrator.js",
