{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile=false --config.strict-dep-builds=false && ./node_modules/.bin/turbo run build --filter='./packages/*'",
  "buildCommand": "./node_modules/.bin/next build --webpack",
  "outputDirectory": ".next"
}
