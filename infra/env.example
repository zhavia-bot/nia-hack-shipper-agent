# =============================================================================
# autoresearch-money — env.example
# Source of truth for required environment variables.
# Real secrets live in Doppler project `autoresearch-money`.
# Per-app subsets are pulled into Vercel / Convex / Tensorlake at deploy time.
# =============================================================================

# ---- Apex / domain ----------------------------------------------------------
# P7.9: storefront namespace. For hackathon, set to `<team>.vercel.app` (or
# `<user>.vercel.app` on hobby) and add `*.<that>.vercel.app` once in the
# Vercel project's Domains tab. Cloudflare DNS tokens are no longer needed.
APEX_DOMAIN=keepalive-club.vercel.app

# ---- Stripe (money rails) ---------------------------------------------------
# Restricted key — agent identity. Resource scope:
#   products.create, prices.create, checkout.sessions.{create,retrieve},
#   events.{list,retrieve}. NEVER refunds/transfers/customers.write.
# Defense-in-depth on top of this is the action allowlist Proxy in
# apps/parent-agent/src/tools/stripe.ts (do not bypass).
STRIPE_RESTRICTED_KEY=rk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Separate key for the refund-worker (Vercel function only). Never injected
# into the agent sandbox.
STRIPE_REFUND_KEY=rk_test_REPLACE_ME

# ---- Convex (state) ---------------------------------------------------------
# Public URL — safe to expose to client. Used by Next.js apps and the agent.
NEXT_PUBLIC_CONVEX_URL=https://REPLACE_ME.convex.cloud
CONVEX_URL=https://REPLACE_ME.convex.cloud
# Deploy key (deploys code; does NOT enforce row-level ACLs — see
# AGENTS.md invariant #5).
CONVEX_DEPLOY_KEY=REPLACE_ME

# ---- packages/auth (custom JWT) ---------------------------------------------
# RS256 keypair (PEM, base64-encoded). Used by `packages/auth` to mint
# service identity tokens (agent, stripe-webhook, refund-worker, dashboard,
# admin, budget-watchdog). RS256 chosen so service JWTs can validate
# through Convex's auth.config.ts alongside Clerk human sessions, which
# only accepts asymmetric algorithms.
#
# Generate:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl rsa -pubout -in priv.pem -out pub.pem
#   AUTH_JWT_PRIVATE_KEY=$(base64 -i priv.pem)   # only on minting host
#   AUTH_JWT_PUBLIC_KEY=$(base64 -i pub.pem)     # also set on Convex env
AUTH_JWT_PRIVATE_KEY=REPLACE_ME_base64_pkcs8_pem
AUTH_JWT_PUBLIC_KEY=REPLACE_ME_base64_spki_pem
# Per-identity tokens issued at boot from the secret above.
CONVEX_AGENT_TOKEN=
CONVEX_STRIPE_WEBHOOK_TOKEN=
CONVEX_REFUND_WORKER_TOKEN=
CONVEX_DASHBOARD_TOKEN=
CONVEX_ADMIN_TOKEN=
# Storefronts run server-side with the stripe-webhook identity (covers
# both webhook ingest and the deliver-route's storage:getUrl reads).
CONVEX_STOREFRONT_TOKEN=
# Dashboard uses Convex realtime in the BROWSER, so its dashboard token
# must be public (NEXT_PUBLIC_*). The token is read-only across all
# tables (`dashboard` identity in `convex/_lib/identity.ts`); the
# dashboard itself is hidden behind basic-auth (`DASHBOARD_BASIC_AUTH`)
# so this token never leaks past authenticated users.
NEXT_PUBLIC_CONVEX_DASHBOARD_TOKEN=
# Basic-auth credentials (format: `user:password`). Vestigial — replaced
# by Clerk; remove from `.env.local` once Clerk verified end-to-end.
DASHBOARD_BASIC_AUTH=

# ---- Clerk (human auth) -----------------------------------------------------
# Clerk authenticates real users on the dashboard. Service identities (agent,
# stripe-webhook, refund-worker, dashboard) keep using the custom RS256 JWTs
# above — they don't go through Clerk.
#
# Setup:
#   1. Create a Clerk app at clerk.com.
#   2. Dashboard → JWT Templates → "Convex" integration. Note the Frontend
#      API URL (= CLERK_JWT_ISSUER_DOMAIN).
#   3. Configure a webhook for user.created/updated/deleted pointing at
#      `<convex-site-url>/clerk-webhook`. Copy the Signing Secret.
#   4. Set CLERK_JWT_ISSUER_DOMAIN + CLERK_WEBHOOK_SECRET on Convex env via
#      `npx convex env set`.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/console
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/console
# These two only need to be set on Convex env (not .env.local):
#   CLERK_JWT_ISSUER_DOMAIN=https://<your-app>.clerk.accounts.dev
#   CLERK_WEBHOOK_SECRET=whsec_REPLACE_ME

# ---- Storefronts (deliver-token signing) ------------------------------------
# HMAC secret for signed download URLs (post-purchase). Min 32 bytes.
# Per stack.md §10.3: tokens are short-lived; the deliver route still
# re-confirms `payment_status === "paid"` before serving bytes.
DELIVER_TOKEN_SECRET=REPLACE_ME_with_32_byte_random
# Optional public base URL override for the storefront — defaults to
# `https://<subdomain>.<APEX_DOMAIN>`. Set this for local dev only.
PUBLIC_BASE_URL=

# ---- Vercel (hosting) -------------------------------------------------------
VERCEL_TOKEN=REPLACE_ME
VERCEL_TEAM_ID=
VERCEL_STOREFRONTS_PROJECT_ID=
VERCEL_DASHBOARD_PROJECT_ID=

# ---- Tensorlake (agent body) ------------------------------------------------
TENSORLAKE_API_KEY=REPLACE_ME

# ---- LLM providers ----------------------------------------------------------
ANTHROPIC_API_KEY=REPLACE_ME
OPENAI_API_KEY=REPLACE_ME

# ---- Image generation -------------------------------------------------------
# Primary: gpt-image-2 via OPENAI_API_KEY above.
# Fallback: FLUX 2 Pro via fal.ai.
FAL_API_KEY=REPLACE_ME

# ---- External hands ---------------------------------------------------------
BROWSERBASE_API_KEY=REPLACE_ME
BROWSERBASE_PROJECT_ID=
RESEND_API_KEY=REPLACE_ME

# ---- External sense organs --------------------------------------------------
EXA_API_KEY=REPLACE_ME
REACHER_API_KEY=REPLACE_ME
# Optional. If unset, the agent calls GET /shops on first use and picks
# the first shop. Required header on every Reacher request except /shops.
REACHER_SHOP_ID=
NIA_API_KEY=REPLACE_ME

# ---- Observability ----------------------------------------------------------
SENTRY_DSN=

# ---- Feature flags ----------------------------------------------------------
# When true, the kill-switch is honored and the parent loop refuses to act.
# Manual override via Convex `budgetState.killSwitchHalt`.
KILL_SWITCH=false
